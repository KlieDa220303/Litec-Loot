---
import type { CollectionEntry } from "astro:content";

export interface Props {
    products: CollectionEntry<"products">[];
}

const { products } = Astro.props;

const companyMap = products.reduce(
    (acc, product) => {
        const company = product.data.company;
        acc[company] = (acc[company] || 0) + 1;
        return acc;
    },
    {} as Record<string, number>,
);

const companies = Object.entries(companyMap).sort((a, b) => b[1] - a[1]);

const INITIAL_COUNT = 5;
---

<div class="mb-8">
    <h2 class="text-xl font-semibold mb-4">Browse by Company</h2>

    <div class="flex flex-wrap gap-2">
        {/* immer sichtbar */}
        {
            companies.slice(0, INITIAL_COUNT).map(([company, count]) => (
                <a
                    href={`/company/${company}`}
                    data-company={company}
                    class="company-item bg-white border border-gray-200 rounded-full px-4 py-1 hover:bg-indigo-50 hover:border-indigo-300 transition-colors flex items-center"
                >
                    <span class="company-name">{company}</span>
                    <span class="ml-2 bg-gray-100 px-2 py-0.5 rounded-full text-xs text-gray-600">
                        {count}
                    </span>
                    <span class="company-check ml-2 hidden text-xs">✓</span>
                </a>
            ))
        }

        {/* versteckte Companies */}
        <div id="more-companies" class="hidden flex flex-wrap gap-2">
            {
                companies.slice(INITIAL_COUNT).map(([company, count]) => (
                    <a
                        href={`/company/${company}`}
                        data-company={company}
                        class="company-item bg-white border border-gray-200 rounded-full px-4 py-1 hover:bg-indigo-50 hover:border-indigo-300 transition-colors flex items-center"
                    >
                        <span class="company-name">{company}</span>
                        <span class="ml-2 bg-gray-100 px-2 py-0.5 rounded-full text-xs text-gray-600">
                            {count}
                        </span>
                        <span class="company-check ml-2 hidden text-xs">✓</span>
                    </a>
                ))
            }
        </div>
    </div>

    {/* Button */}
    {companies.length > INITIAL_COUNT && (
        <button
            id="toggle-btn"
            class="mt-3 text-indigo-600 hover:underline text-sm"
        >
            Show more
        </button>
    )}
</div>

<script>
    const btn = document.getElementById('toggle-btn');
    const more = document.getElementById('more-companies');

    if (btn && more) {
        btn.addEventListener('click', () => {
            const isHidden = more.classList.contains('hidden');

            more.classList.toggle('hidden');
            btn.textContent = isHidden ? 'Show less' : 'Show more';
        });
    }

    // Multi-select behavior for companies
    const selectedCompanies = new Set((JSON.parse(sessionStorage.getItem('filters') || '{}').companies) || []);
    function updateCompanyUI() {
        document.querySelectorAll('.company-item').forEach(el => {
            const c = el.getAttribute('data-company');
            const check = el.querySelector('.company-check');
            if (selectedCompanies.has(c)) {
                if (check) check.classList.remove('hidden');
                el.classList.add('bg-indigo-50');
            } else {
                if (check) check.classList.add('hidden');
                el.classList.remove('bg-indigo-50');
            }
        });
    }

    document.querySelectorAll('.company-item').forEach(el => {
        el.addEventListener('click', (e) => {
            e.preventDefault();
            const c = el.getAttribute('data-company');
            if (!c) return;
            if (selectedCompanies.has(c)) selectedCompanies.delete(c);
            else selectedCompanies.add(c);
            const stored = JSON.parse(sessionStorage.getItem('filters') || '{}');
            stored.companies = Array.from(selectedCompanies);
            sessionStorage.setItem('filters', JSON.stringify(stored));
            updateCompanyUI();
            if (window.applyFilters) window.applyFilters(stored);
        });
    });

    // Restore UI
    updateCompanyUI();

    window.filterResetHandlers = window.filterResetHandlers || [];
    window.filterResetHandlers.push(() => {
        selectedCompanies.clear();
        updateCompanyUI();
    });
</script>