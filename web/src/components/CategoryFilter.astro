---
import type { CollectionEntry } from "astro:content";

export interface Props {
    products: CollectionEntry<"products">[];
}

const { products } = Astro.props;

// Get categories with counts
const categoryMap = products.reduce(
    (acc, product) => {
        const category = product.data.category;
        acc[category] = (acc[category] || 0) + 1;
        return acc;
    },
    {} as Record<string, number>,
);

// Sort categories by count (descending)
const categories = Object.entries(categoryMap).sort((a, b) => b[1] - a[1]);
const INITIAL_COUNT = 5;
---

<div class="mb-8">
    <h2 class="text-xl font-semibold mb-4">Browse by Category</h2>

    <div class="flex flex-wrap gap-2">
        {/* sichtbar */}
        {
            categories.slice(0, INITIAL_COUNT).map(([category, count]) => (
                <a
                    href={`/category/${category}`}
                    data-category={category}
                    class="category-item bg-white border border-gray-200 rounded-full px-4 py-1 hover:bg-indigo-50 hover:border-indigo-300 transition-colors flex items-center"
                >
                    <span class="category-name">{category}</span>
                    <span class="ml-2 bg-gray-100 px-2 py-0.5 rounded-full text-xs text-gray-600">
                        {count}
                    </span>
                    <span class="category-check ml-2 hidden text-xs">✓</span>
                </a>
            ))
        }

        {/* versteckt */}
        <div id="more-categories" class="hidden flex flex-wrap gap-2">
            {
                categories.slice(INITIAL_COUNT).map(([category, count]) => (
                    <a
                        href={`/category/${category}`}
                        data-category={category}
                        class="category-item bg-white border border-gray-200 rounded-full px-4 py-1 hover:bg-indigo-50 hover:border-indigo-300 transition-colors flex items-center"
                    >
                        <span class="category-name">{category}</span>
                        <span class="ml-2 bg-gray-100 px-2 py-0.5 rounded-full text-xs text-gray-600">
                            {count}
                        </span>
                        <span class="category-check ml-2 hidden text-xs">✓</span>
                    </a>
                ))
            }
        </div>
    </div>

    {/* Button */}
    {categories.length > INITIAL_COUNT && (
        <button
            id="toggle-categories"
            class="mt-3 text-indigo-600 hover:underline text-sm"
        >
            Show more
        </button>
    )}
</div>

{/* Script */}
<script>
    const btn = document.getElementById('toggle-categories');
    const more = document.getElementById('more-categories');

    if (btn && more) {
        btn.addEventListener('click', () => {
            const isHidden = more.classList.contains('hidden');

            more.classList.toggle('hidden');
            btn.textContent = isHidden ? 'Show less' : 'Show more';
        });
    }

    // Multi-select behavior
    const selectedCategories = new Set();
    function updateCategoryUI() {
        document.querySelectorAll('.category-item').forEach(el => {
            const cat = el.getAttribute('data-category');
            const check = el.querySelector('.category-check');
            if (selectedCategories.has(cat)) {
                if (check) check.classList.remove('hidden');
                el.classList.add('bg-indigo-50');
            } else {
                if (check) check.classList.add('hidden');
                el.classList.remove('bg-indigo-50');
            }
        });
    }

    document.querySelectorAll('.category-item').forEach(el => {
        el.addEventListener('click', (e) => {
            e.preventDefault();
            const cat = el.getAttribute('data-category');
            if (!cat) return;
            if (selectedCategories.has(cat)) selectedCategories.delete(cat);
            else selectedCategories.add(cat);
            // Persist
            sessionStorage.setItem('filters', JSON.stringify({
                categories: Array.from(selectedCategories),
                companies: JSON.parse(sessionStorage.getItem('filters') || '{}').companies || [],
                years: JSON.parse(sessionStorage.getItem('filters') || '{}').years || []
            }));
            updateCategoryUI();
            // apply
            if (window.applyFilters) {
                const stored = JSON.parse(sessionStorage.getItem('filters') || '{}');
                window.applyFilters(stored);
            }
        });
    });

    // Restore selections
    const saved = JSON.parse(sessionStorage.getItem('filters') || '{}');
    if (saved && Array.isArray(saved.categories)) {
        saved.categories.forEach(c => selectedCategories.add(c));
        updateCategoryUI();
    }
</script>