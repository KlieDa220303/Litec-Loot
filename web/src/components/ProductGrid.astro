---
import ProductCard from "./ProductCard.astro";
import type { CollectionEntry } from "astro:content";

export interface Props {
    products: CollectionEntry<"products">[];
    title?: string;
    itemsPerPage?: number;
}

const { products, title, itemsPerPage = 20 } = Astro.props;
---

<div class="mb-8">
    {title && <h1 class="text-3xl font-bold text-gray-800 mb-6">{title}</h1>}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="product-grid">
        {
            products.slice(0, itemsPerPage).map((product) => (
                <ProductCard
                    id={product.id}
                    product={product.data.product}
                    company={product.data.company}
                    category={product.data.category}
                    rating={product.data.rating}
                />
            ))
        }
    </div>

    {
        products.length === 0 && (
            <p class="text-gray-500 text-center py-10">No products found.</p>
        )
    }

    {
        products.length > itemsPerPage && (
            <div class="flex justify-center items-center gap-2 mt-8">
                <button
                    id="prev-btn"
                    class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 disabled:bg-gray-400 disabled:cursor-not-allowed"
                    disabled
                >
                    ← Previous
                </button>
                <div id="page-info" class="text-gray-600 font-medium">Page <span id="current-page">1</span> of <span id="total-pages">1</span></div>
                <button
                    id="next-btn"
                    class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 disabled:bg-gray-400 disabled:cursor-not-allowed"
                >
                    Next →
                </button>
            </div>
        )
    }
</div>

<script define:vars={{ products: JSON.stringify(products), itemsPerPage }}>
    const allProducts = JSON.parse(products);
    let currentPage = 1;
    const totalPages = Math.ceil(allProducts.length / itemsPerPage);

    function createProductCard(product) {
        const card = document.createElement("div");
        card.innerHTML = `
            <div class="bg-white rounded-lg shadow-lg overflow-hidden transition-transform hover:scale-105">
                <a href="/product/${product.id}" class="block overflow-hidden bg-gray-100">
                    <img
                        src="/${product.id}.jpg"
                        alt="${product.data.product}"
                        class="w-full h-56 object-cover transition-transform duration-300 hover:scale-105"
                        loading="lazy"
                    />
                </a>
                <div class="p-5 relative">
                    <a
                        href="/rating/filter/${product.data.rating}"
                        class="absolute top-2 right-2 bg-indigo-600 text-white rounded-full w-10 h-10 flex items-center justify-center font-bold"
                    >
                        ${product.data.rating}
                    </a>
                    <h2 class="text-xl font-bold mt-2 mb-3">
                        <a href="/product/${product.id}" class="text-indigo-700 hover:underline">
                            ${product.data.product}
                        </a>
                    </h2>
                    <div class="flex flex-col space-y-2 text-sm text-gray-600">
                        <div>
                            <span class="font-medium">Company:</span>
                            <a href="/company/${product.data.company}" class="text-indigo-600 hover:underline">
                                ${product.data.company}
                            </a>
                        </div>
                        <div>
                            <span class="font-medium">Category:</span>
                            <a href="/category/${product.data.category}" class="text-indigo-600 hover:underline">
                                ${product.data.category}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        `;
        return card.firstElementChild;
    }

    function renderPage(page) {
        const grid = document.getElementById("product-grid");
        const startIndex = (page - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;
        const pageProducts = allProducts.slice(startIndex, endIndex);

        grid.innerHTML = "";
        pageProducts.forEach((product) => {
            const card = createProductCard(product);
            grid.appendChild(card);
        });

        document.getElementById("current-page").textContent = page;
        document.getElementById("prev-btn").disabled = page === 1;
        document.getElementById("next-btn").disabled = page === totalPages;

        window.scrollTo({ top: 0, behavior: "smooth" });
    }

    document.getElementById("prev-btn")?.addEventListener("click", () => {
        if (currentPage > 1) {
            currentPage--;
            renderPage(currentPage);
        }
    });

    document.getElementById("next-btn")?.addEventListener("click", () => {
        if (currentPage < totalPages) {
            currentPage++;
            renderPage(currentPage);
        }
    });

    document.getElementById("total-pages").textContent = totalPages;

    // Expose a global filter function for other components
    window.applyFilters = function(filters) {
        const grid = document.getElementById("product-grid");
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const pageInfo = document.getElementById('page-info');

        // If no filters, restore paginated view
        const hasAnyFilter = (filters && ((filters.categories && filters.categories.length) || (filters.companies && filters.companies.length) || (filters.years && filters.years.length)));
        if (!hasAnyFilter) {
            // show pagination
            if (prevBtn) prevBtn.style.display = '';
            if (nextBtn) nextBtn.style.display = '';
            if (pageInfo) pageInfo.style.display = '';
            renderPage(currentPage);
            return;
        }

        // Filter products
        const filtered = allProducts.filter(p => {
            const matchCategory = !filters.categories || filters.categories.length === 0 || filters.categories.includes(p.data.category);
            const matchCompany = !filters.companies || filters.companies.length === 0 || filters.companies.includes(p.data.company);
            const matchYear = !filters.years || filters.years.length === 0 || filters.years.includes(String(p.data.year));
            return matchCategory && matchCompany && matchYear;
        });

        // Sort so matching categories come first (no-op if none)
        // (keeping stable ordering otherwise)

        grid.innerHTML = '';
        if (filtered.length === 0) {
            grid.innerHTML = '<p class="text-gray-500 text-center py-10 col-span-full">No products found.</p>';
        } else {
            filtered.forEach(product => {
                const card = createProductCard(product);
                grid.appendChild(card);
            });
        }

        if (prevBtn) prevBtn.style.display = 'none';
        if (nextBtn) nextBtn.style.display = 'none';
        if (pageInfo) pageInfo.style.display = 'none';
    }

    // On load, if there are saved filters, apply them
    const savedFilters = JSON.parse(sessionStorage.getItem('filters') || '{}');
    const hasSaved = savedFilters && ((savedFilters.categories && savedFilters.categories.length) || (savedFilters.companies && savedFilters.companies.length) || (savedFilters.years && savedFilters.years.length));
    if (hasSaved) {
        window.applyFilters(savedFilters);
    } else {
        renderPage(currentPage);
    }
</script>
